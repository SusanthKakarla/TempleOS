# Railway Postgres
DATABASE_URL=postgresql://user:password@host:port/database

# Session cookie signing (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SESSION_SECRET=

# Firebase Admin SDK (server-side token verification)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Firebase client SDK (browser phone OTP login)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=

# Local tenant login host override. Must match a tenant_domains.hostname row;
# Local-only override for tenant login on localhost. Use the hostname of a real
# tenant created through `/super-admin/temples/new` or `npm run provision:temple`.
TEMPLEOS_LOCAL_TENANT_HOST=your-temple.trytempleos.com

# Meta WhatsApp Cloud API
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# Meta WhatsApp Embedded Signup (tenant self-connect, Chatbot Settings page).
# TempleOS acts as a Meta Tech Provider: WHATSAPP_ACCESS_TOKEN above is a
# single platform-level System User token used for every connected tenant's
# Graph API calls once Embedded Signup grants that System User access to
# their WhatsApp Business Account — no per-tenant token is ever stored.
NEXT_PUBLIC_WHATSAPP_APP_ID=
NEXT_PUBLIC_WHATSAPP_CONFIG_ID=
WHATSAPP_APP_SECRET=

# Meta's JS SDK doesn't support wildcard Allowed Domains, so the actual
# FB.init()/FB.login() call always runs from this single fixed domain
# (app/whatsapp-onboarding) instead of the tenant's own subdomain — the
# tenant dashboard hands off here and gets handed back after connecting.
WHATSAPP_ONBOARDING_ORIGIN=https://trytempleos.com

# Bootstrap Super Admin (read once by `npm run seed`; no-ops if a Super Admin
# already exists, so it's safe to leave set on every deploy)
ADMIN_PHONE_NUMBER=
ADMIN_DISPLAY_NAME=

# Shared secret for Railway Cron to call /api/cron/process-event-notifications
# (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
CRON_SECRET=
